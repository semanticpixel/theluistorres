---
import Base from "~/layouts/Base.astro";
import WorkCard from "~/components/WorkCard.astro";
import FallbackRibbon from "~/components/FallbackRibbon.astro";
import { listWorkForLocale } from "~/lib/content";

const locale = "es" as const;
const entries = (await listWorkForLocale(locale))
  .sort((a, b) => b.entry.data.date.valueOf() - a.entry.data.date.valueOf());

const anyUntranslated = entries.some(e => !e.translated);
---

<Base title="Trabajo — Luis Torres" description="Casos de estudio en ingeniería de diseño — LinkedIn, Superhuman, Grammarly.">
  {anyUntranslated && <FallbackRibbon locale={locale} />}
  <main class="work-index">
    <header class="work-index__head">
      <p class="work-index__eyebrow">trabajo</p>
      <h1 class="work-index__title">Casos de estudio</h1>
      <p class="work-index__lede">
        Cinco proyectos, cada uno escrito para que las decisiones lean claramente — cuál era la
        restricción, cuál fue el movimiento, qué costó. Cada entrada termina con <em>qué haría
        diferente</em>, que suele ser la parte que vale la pena leer.
      </p>
    </header>

    <div class="work-index__grid">
      {entries.map(({ entry }) => <WorkCard entry={entry} headingLevel={2} />)}
    </div>
  </main>
</Base>

<style>
  .work-index {
    max-width: var(--container-wide);
    margin-inline: auto;
    padding: var(--space-8) var(--space-5) var(--space-10);
    display: grid;
    gap: var(--space-8);
  }

  .work-index__head {
    display: grid;
    gap: var(--space-3);
    padding-block-end: var(--space-5);
    border-block-end: 1px solid var(--color-border);
    max-width: 56ch;
  }

  .work-index__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--type-12);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: lowercase;
  }

  .work-index__title {
    font-family: var(--font-display);
    font-size: var(--type-64);
    line-height: var(--line-tight);
    letter-spacing: var(--tracking-tight);
  }

  .work-index__lede {
    color: var(--color-text-muted);
  }

  .work-index__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: var(--space-5);
  }
</style>
